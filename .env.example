# Copy this file to .env.local for local testing (never commit .env.local).
# In production, set this in Vercel: Settings → Environment Variables.

META_CAPI_ACCESS_TOKEN=your_new_token_here

# Zoho CRM (used by /api/submit-lead to create a Lead on every form submission)
ZOHO_CRM_CLIENT_ID=your_self_client_id_here
ZOHO_CRM_CLIENT_SECRET=your_self_client_secret_here
ZOHO_CRM_REFRESH_TOKEN=your_refresh_token_here
ZOHO_CRM_API_DOMAIN=https://www.zohoapis.com
